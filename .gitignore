# Dependencias de Node
node_modules/
npm-debug.log*

# Carpeta de compilación de Electron
dist/

# Archivos de subida (No queremos tus archivos personales en GitHub)
uploads/*
!uploads/.gitkeep

# Android / Capacitor (Generalmente se generan localmente)
# Si querés que otros puedan compilar tu app fácil, podés NO ignorar 'android'
# Pero lo estándar es ignorar las carpetas de compilación
android/app/build/
android/.gradle/
android/local.properties
android/.idea/

# Ignorar contenido de descargas pero mantener la carpeta
www/downloads/*
!www/downloads/.gitkeep

# Archivos temporales de descarga
downloads/
uploads/

# Archivos de sistema y logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.DS_Store

# Archivos del Sistema
.DS_Store
Thumbs.db
.env